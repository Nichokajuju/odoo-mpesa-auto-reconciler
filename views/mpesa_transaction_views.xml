<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="mpesa_transaction_view_list" model="ir.ui.view">
        <field name="name">mpesa.transaction.view.list</field>
        <field name="model">mpesa.transaction</field>
        <field name="arch" type="xml">
            <list string="M-Pesa Transactions"
                  decoration-success="state == 'reconciled'"
                  decoration-warning="state == 'matched'"
                  decoration-danger="state == 'failed'"
                  decoration-muted="state == 'pending'">
                <header>
                    <button name="action_batch_match"
                            string="Batch Match"
                            type="object"/>
                    <button name="action_batch_reconcile"
                            string="Batch Reconcile"
                            type="object"/>
                </header>
                <field name="transaction_id"/>
                <field name="transaction_date"/>
                <field name="amount"/>
                <field name="phone_number"/>
                <field name="sender_name"/>
                <field name="reference"/>
                <field name="transaction_type"/>
                <field name="partner_id"/>
                <field name="invoice_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="mpesa_transaction_view_form" model="ir.ui.view">
        <field name="name">mpesa.transaction.view.form</field>
        <field name="model">mpesa.transaction</field>
        <field name="arch" type="xml">
            <form string="M-Pesa Transaction">
                <header>
                    <button name="action_match_invoice"
                            string="Match Invoice"
                            type="object"
                            class="btn-primary"
                            invisible="state in ['matched', 'reconciled']"/>
                    <button name="action_reconcile"
                            string="Reconcile"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'matched'"/>
                    <button name="action_reset_to_pending"
                            string="Reset to Pending"
                            type="object"
                            invisible="state in ['pending', 'reconciled']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,matched,reconciled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="transaction_id" placeholder="Transaction ID"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Transaction Details">
                            <field name="transaction_date"/>
                            <field name="amount"/>
                            <field name="transaction_type"/>
                            <field name="phone_number"/>
                            <field name="sender_name"/>
                            <field name="reference"/>
                        </group>
                        <group string="Reconciliation Details">
                            <field name="partner_id"/>
                            <field name="invoice_id"/>
                            <field name="payment_id"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="mpesa_transaction_view_search" model="ir.ui.view">
        <field name="name">mpesa.transaction.view.search</field>
        <field name="model">mpesa.transaction</field>
        <field name="arch" type="xml">
            <search string="Search Transactions">
                <field name="transaction_id"/>
                <field name="phone_number"/>
                <field name="sender_name"/>
                <field name="reference"/>
                <field name="partner_id"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Matched" name="matched" domain="[('state','=','matched')]"/>
                <filter string="Reconciled" name="reconciled" domain="[('state','=','reconciled')]"/>
                <filter string="Failed" name="failed" domain="[('state','=','failed')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Transaction Type" name="group_type" context="{'group_by': 'transaction_type'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="mpesa_transaction_action" model="ir.actions.act_window">
        <field name="name">M-Pesa Transactions</field>
        <field name="res_model">mpesa.transaction</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mpesa_transaction_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No M-Pesa transactions yet!
            </p>
            <p>Create your first transaction or configure the Daraja API to import automatically.</p>
        </field>
    </record>

</odoo>
